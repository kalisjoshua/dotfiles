# User Information

[user]
	name = Joshua Kalis
	email = kalisjoshua@gmail.com
	signingkey = ~/.ssh/id_ecdsa.pub

# Custom Aliases

[alias]
	count = rev-list --count HEAD
	graph = log --all --decorate --oneline --graph
	lg = log -F --graph --pretty=format:'%Cgreen%h%Creset -%d %s (%Cgreen%ad%Creset) %ae'
	squash = !sh -c 'git rebase -i $(git merge-base HEAD $1)' -
	who = shortlog -s --
	sw=!git branch | fzf | xargs git switch
[color]
	ui = auto
[push]
	default = simple
[core]
	excludesfile = ~/.gitignore
[init]
	defaultBranch = main
[pull]
	rebase = true

# Conditional Includes
# Default identity (above) is personal. Override to work for any repo under a `khan/` directory,
# matched anywhere on disk so it holds across machines.

[includeIf "gitdir:**/khan/**"]
	path = ~/.gitconfig-work
[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
